<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>WSN – Terminal Dostępu</title>

<style>
body {
    margin: 0;
    background: #000;
    color: #00ff66;
    font-family: "Courier New", monospace;
    overflow: hidden;
}

#terminal {
    padding: 40px;
    white-space: pre-wrap;
    font-size: 16px;
}

.input-line {
    display: flex;
    align-items: center;
}

input {
    background: transparent;
    border: none;
    outline: none;
    color: #00ff66;
    font-family: inherit;
    font-size: 16px;
    width: 200px;
}

.glitch {
    animation: glitch 0.2s infinite;
}

@keyframes glitch {
    0% { text-shadow: 2px 0 red; }
    50% { text-shadow: -2px 0 blue; }
    100% { text-shadow: 2px 0 red; }
}

.blink {
    animation: blink 1s infinite;
}

@keyframes blink {
    0%, 50%, 100% { opacity: 1; }
    25%, 75% { opacity: 0; }
}
</style>
</head>
<body>

<div id="terminal"></div>

<script>
const terminal = document.getElementById("terminal");
const poprawnyKod = "59142";
let proby = 0;
let blokada = false;

function typeText(text, delay = 30) {
    return new Promise(resolve => {
        let i = 0;
        const interval = setInterval(() => {
            terminal.innerHTML += text[i];
            i++;
            if (i >= text.length) {
                clearInterval(interval);
                resolve();
            }
        }, delay);
    });
}

async function startTerminal() {
    await typeText("WSN SYSTEM OPERACYJNY v4.2\n");
    await typeText("Autoryzacja dostępu do ARCHIWUM...\n");
    await typeText("Wprowadź 5-cyfrowy kod dostępu.\n\n");
    createInput();
}

function createInput() {
    const line = document.createElement("div");
    line.className = "input-line";
    line.innerHTML = "> ";
    
    const input = document.createElement("input");
    input.maxLength = 5;
    input.autofocus = true;

    input.addEventListener("keydown", function(e) {
        if (e.key === "Enter") {
            sprawdzKod(input.value);
        }
    });

    line.appendChild(input);
    terminal.appendChild(line);
    input.focus();
}

function sprawdzKod(kod) {
    if (blokada) return;

    terminal.innerHTML += "\nWeryfikacja...\n";

    if (kod === poprawnyKod) {
        terminal.innerHTML += "DOSTĘP PRZYZNANY.\n";
        setTimeout(() => {
            window.location.href = "dostep-archiwum.html";
        }, 1500);
    } else {
        proby++;
        terminal.innerHTML += "BŁĄD. KOD NIEPRAWIDŁOWY.\n";

        document.body.classList.add("glitch");
        setTimeout(() => {
            document.body.classList.remove("glitch");
        }, 400);

        if (proby >= 3) {
            blokada = true;
            terminal.innerHTML += "\nSYSTEM ZABLOKOWANY.\n";
            terminal.innerHTML += "Zgłoszono próbę nieautoryzowanego dostępu.\n";
        } else {
            createInput();
        }
    }
}

startTerminal();
</script>

</body>
</html>